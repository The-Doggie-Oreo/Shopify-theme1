<section class="hero kg3d-hero" id="hero-{{ section.id }}">
  {% if section.settings.hero_image %}
  <div class="hero-background">
    {{ section.settings.hero_image | image_url: width: 2400 | image_tag:
      class: 'hero-image',
      loading: 'eager',
      widths: '750, 1100, 1500, 2000, 2400',
      sizes: '100vw',
      alt: section.settings.heading
    }}
    <div class="hero-overlay"></div>
  </div>
  {% endif %}
  
  <div class="hero-particles" aria-hidden="true">
    <div class="particle"></div>
    <div class="particle"></div>
    <div class="particle"></div>
    <div class="particle"></div>
    <div class="particle"></div>
    <div class="particle"></div>
    <div class="particle"></div>
    <div class="particle"></div>
  </div>

  <div class="container">
    <div class="hero-content">
      {% if section.settings.badge_text %}
      <div class="hero-badge animate-fade-in-up">
        <span class="badge badge-primary">{{ section.settings.badge_text }}</span>
      </div>
      {% endif %}

      {% if section.settings.heading %}
      <h1 class="hero-title animate-fade-in-up">
        {{ section.settings.heading }}
      </h1>
      {% endif %}

      {% if section.settings.subheading %}
      <p class="hero-subtitle animate-fade-in-up">
        {{ section.settings.subheading }}
      </p>
      {% endif %}

      <div class="hero-actions animate-fade-in-up">
        {% if section.settings.cta_label and section.settings.cta_link %}
        <a href="{{ section.settings.cta_link }}" class="btn btn-primary btn-lg">
          {{ section.settings.cta_label }}
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </a>
        {% endif %}
        
        {% if section.settings.cta2_label and section.settings.cta2_link %}
        <a href="{{ section.settings.cta2_link }}" class="btn btn-secondary btn-lg">
          {{ section.settings.cta2_label }}
        </a>
        {% endif %}
      </div>

      {% if section.settings.show_search %}
      <div class="hero-search animate-fade-in-up" role="search">
        <div class="search-container">
          <input type="search" class="search-input" aria-label="Search materials or upload files" placeholder="Upload your STL file or search for materials...">
          <button class="btn btn-primary">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
              <polyline points="17 8 12 3 7 8"/>
              <line x1="12" y1="3" x2="12" y2="15"/>
            </svg>
            Upload File
          </button>
        </div>
      </div>
      {% endif %}
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="hero-scroll">
    <div class="scroll-indicator">
      <span class="scroll-text">Scroll to explore</span>
      <div class="scroll-arrow">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <polyline points="6 9 12 15 18 9"/>
        </svg>
      </div>
    </div>
  </div>
</section>

<style>
.hero {
  position: relative;
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.hero-background {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 1;
}

.hero-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center;
}

.hero-overlay {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: linear-gradient(135deg, 
    rgba(0, 0, 0, 0.7) 0%, 
    rgba(0, 0, 0, 0.5) 50%, 
    rgba(0, 0, 0, 0.8) 100%
  );
}

.hero-particles {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 2;
  pointer-events: none;
}

.particle {
  position: absolute;
  background-color: rgba(255, 255, 255, 0.1);
  border-radius: 50%;
  animation: float 20s infinite ease-in-out;
}

.particle:nth-child(1) {
  width: 4px;
  height: 4px;
  left: 10%;
  top: 20%;
  animation-delay: 0s;
  animation-duration: 25s;
}

.particle:nth-child(2) {
  width: 6px;
  height: 6px;
  left: 20%;
  top: 60%;
  animation-delay: 2s;
  animation-duration: 20s;
}

.particle:nth-child(3) {
  width: 3px;
  height: 3px;
  left: 60%;
  top: 30%;
  animation-delay: 4s;
  animation-duration: 30s;
}

.particle:nth-child(4) {
  width: 5px;
  height: 5px;
  left: 80%;
  top: 70%;
  animation-delay: 1s;
  animation-duration: 22s;
}

.particle:nth-child(5) {
  width: 4px;
  height: 4px;
  left: 30%;
  top: 80%;
  animation-delay: 3s;
  animation-duration: 28s;
}

.particle:nth-child(6) {
  width: 7px;
  height: 7px;
  left: 70%;
  top: 10%;
  animation-delay: 5s;
  animation-duration: 25s;
}

.particle:nth-child(7) {
  width: 3px;
  height: 3px;
  left: 90%;
  top: 40%;
  animation-delay: 2s;
  animation-duration: 20s;
}

.particle:nth-child(8) {
  width: 5px;
  height: 5px;
  left: 50%;
  top: 90%;
  animation-delay: 4s;
  animation-duration: 30s;
}

@keyframes float {
  0%, 100% {
    transform: translateY(0px) translateX(0px) scale(1);
    opacity: 0.1;
  }
  25% {
    transform: translateY(-20px) translateX(10px) scale(1.1);
    opacity: 0.3;
  }
  50% {
    transform: translateY(-40px) translateX(-10px) scale(0.9);
    opacity: 0.2;
  }
  75% {
    transform: translateY(-20px) translateX(5px) scale(1.05);
    opacity: 0.4;
  }
}

.hero-content {
  position: relative;
  z-index: 3;
  text-align: center;
  max-width: 900px;
  margin: 0 auto;
}

.hero-badge {
  margin-bottom: 2rem;
}

.hero-title {
  margin-bottom: 1.5rem;
  line-height: 1.1;
}

.hero-subtitle {
  margin-bottom: 2.5rem;
  font-size: 1.25rem;
  line-height: 1.6;
  color: rgba(255, 255, 255, 0.9);
}

.hero-actions {
  display: flex;
  gap: 1rem;
  justify-content: center;
  align-items: center;
  flex-wrap: wrap;
  margin-bottom: 3rem;
}

.hero-search {
  margin-top: 2rem;
}

.search-container {
  display: flex;
  gap: 0.75rem;
  max-width: 600px;
  margin: 0 auto;
  background: rgba(255, 255, 255, 0.1);
  backdrop-filter: blur(10px);
  border: 1px solid rgba(255, 255, 255, 0.2);
  border-radius: var(--radius-xl);
  padding: 0.5rem;
}

.search-container .search-input {
  flex: 1;
  background: transparent;
  border: none;
  color: white;
  font-size: 1rem;
  padding: 0.75rem 1rem;
}

.search-container .search-input::placeholder {
  color: rgba(255, 255, 255, 0.7);
}

.search-container .search-input:focus {
  outline: none;
}

.search-container .btn {
  background: var(--primary-color);
  border: none;
  color: white;
  padding: 0.75rem 1.5rem;
  border-radius: var(--radius-md);
  font-weight: 600;
  transition: all var(--transition-base);
}

.search-container .btn:hover {
  background: var(--primary-dark);
  transform: translateY(-2px);
}

.hero-scroll {
  position: absolute;
  bottom: 2rem;
  left: 50%;
  transform: translateX(-50%);
  z-index: 3;
}

.scroll-indicator {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.5rem;
  color: rgba(255, 255, 255, 0.7);
  font-size: 0.875rem;
}

.scroll-arrow {
  animation: bounce 2s infinite;
}

@keyframes bounce {
  0%, 20%, 50%, 80%, 100% {
    transform: translateY(0);
  }
  40% {
    transform: translateY(-10px);
  }
  60% {
    transform: translateY(-5px);
  }
}

/* Staggered animations */
.hero-badge {
  animation-delay: 0.1s;
}

.hero-title {
  animation-delay: 0.3s;
}

.hero-subtitle {
  animation-delay: 0.5s;
}

.hero-actions {
  animation-delay: 0.7s;
}

.hero-search {
  animation-delay: 0.9s;
}

/* Responsive */
@media (max-width: 768px) {
  .hero-content {
    padding: 2rem 1rem;
  }
  
  .hero-actions {
    flex-direction: column;
    align-items: center;
  }
  
  .hero-actions .btn {
    width: 100%;
    max-width: 280px;
  }
  
  .search-container {
    flex-direction: column;
    gap: 0.5rem;
  }
  
  .search-container .btn {
    width: 100%;
  }
  
  .hero-scroll {
    bottom: 1rem;
  }
}

.kg3d-hero {
  --kg-surface: rgba(8, 13, 22, 0.72);
  --kg-surface-strong: rgba(8, 13, 22, 0.9);
  --kg-line: rgba(158, 198, 255, 0.2);
  --kg-line-strong: rgba(91, 166, 255, 0.55);
  --kg-glow: rgba(0, 194, 255, 0.35);
  --kg-accent: var(--primary-color, #00c2ff);
  --kg-radius: 28px;
  --kg-ease: cubic-bezier(0.22, 1, 0.36, 1);
  isolation: isolate;
  background:
    radial-gradient(circle at 76% 20%, rgba(0, 194, 255, 0.18), transparent 32rem),
    linear-gradient(135deg, #05070d 0%, #0a1220 52%, #04060b 100%);
}

.kg3d-hero::before {
  content: "";
  position: absolute;
  inset: 0;
  z-index: 2;
  pointer-events: none;
  background-image:
    linear-gradient(rgba(158, 198, 255, 0.08) 1px, transparent 1px),
    linear-gradient(90deg, rgba(158, 198, 255, 0.08) 1px, transparent 1px);
  background-size: 64px 64px;
  mask-image: radial-gradient(circle at 50% 50%, black, transparent 78%);
}

.kg3d-hero .hero-overlay {
  background:
    linear-gradient(90deg, rgba(2, 6, 14, 0.96) 0%, rgba(2, 6, 14, 0.7) 47%, rgba(2, 6, 14, 0.38) 100%),
    linear-gradient(180deg, rgba(2, 6, 14, 0.18), rgba(2, 6, 14, 0.9));
}

.kg3d-hero .hero-image {
  filter: saturate(0.82) contrast(1.08) brightness(0.78);
  transform: scale(1.025);
}

.kg3d-hero .container {
  position: relative;
  z-index: 4;
  width: min(1180px, calc(100% - 32px));
}

.kg3d-hero .hero-content {
  text-align: left;
  margin: 0;
  max-width: 760px;
  padding: clamp(1.25rem, 3vw, 3rem);
  background: linear-gradient(135deg, var(--kg-surface), rgba(8, 13, 22, 0.46));
  border: 1px solid var(--kg-line);
  border-radius: var(--kg-radius);
  box-shadow: 0 32px 120px rgba(0, 0, 0, 0.52), inset 0 1px 0 rgba(255, 255, 255, 0.08);
  backdrop-filter: blur(22px) saturate(1.25);
}

.kg3d-hero .hero-content::before {
  content: "";
  position: absolute;
  inset: 14px;
  pointer-events: none;
  border: 1px solid rgba(255, 255, 255, 0.06);
  border-radius: calc(var(--kg-radius) - 10px);
}

.kg3d-hero .badge {
  background: rgba(0, 194, 255, 0.12);
  border: 1px solid var(--kg-line-strong);
  color: #dff7ff;
  box-shadow: 0 0 28px rgba(0, 194, 255, 0.18);
  letter-spacing: 0.14em;
  text-transform: uppercase;
}

.kg3d-hero .hero-title {
  max-width: 12ch;
  color: #f6fbff;
  letter-spacing: -0.06em;
  text-wrap: balance;
  font-size: clamp(3.2rem, 8vw, 7.5rem);
}

.kg3d-hero .hero-subtitle {
  max-width: 58ch;
  color: rgba(229, 241, 255, 0.82);
}

.kg3d-hero .hero-actions .btn,
.kg3d-hero .search-container .btn {
  border: 1px solid rgba(127, 211, 255, 0.42);
  box-shadow: 0 14px 38px rgba(0, 194, 255, 0.16);
  transition: transform 420ms var(--kg-ease), box-shadow 420ms var(--kg-ease), border-color 420ms var(--kg-ease);
  will-change: transform;
}

.kg3d-hero .hero-actions .btn:hover,
.kg3d-hero .search-container .btn:hover {
  transform: translate3d(0, -4px, 0);
  box-shadow: 0 20px 54px rgba(0, 194, 255, 0.32);
  border-color: rgba(185, 233, 255, 0.75);
}

.kg3d-hero .search-container {
  margin-inline: 0;
  max-width: 680px;
  background: var(--kg-surface-strong);
  border: 1px solid var(--kg-line);
  border-radius: 18px;
  box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.06);
}

.kg3d-hero .search-container:focus-within {
  border-color: var(--kg-line-strong);
  box-shadow: 0 0 0 4px rgba(0, 194, 255, 0.12), 0 22px 70px rgba(0, 0, 0, 0.3);
}

@media (max-width: 768px) {
  .kg3d-hero .hero-content {
    text-align: center;
  }

  .kg3d-hero .hero-title,
  .kg3d-hero .hero-subtitle {
    margin-inline: auto;
  }
}
</style>

{% schema %}
{
  "name": "Enhanced Hero Section",
  "settings": [
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Hero Background Image"
    },
    {
      "type": "text",
      "id": "badge_text",
      "label": "Badge Text",
      "default": "Now Accepting Orders"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Main Heading",
      "default": "Precision Prints. Delivered."
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "From concept file to finished prototype — industrial-grade 3D printing for creators, engineers, and dreamers."
    },
    {
      "type": "checkbox",
      "id": "show_search",
      "label": "Show File Upload/Search",
      "default": true
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Primary CTA Button",
      "default": "Upload STL"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "Primary CTA Link"
    },
    {
      "type": "text",
      "id": "cta2_label",
      "label": "Secondary CTA Button",
      "default": "Browse Catalog"
    },
    {
      "type": "url",
      "id": "cta2_link",
      "label": "Secondary CTA Link"
    }
  ],
  "presets": [
    {
      "name": "Enhanced Hero",
      "category": "Hero"
    }
  ]
}
{% endschema %}