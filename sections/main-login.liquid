<section class="section kg3d-page kg3d-login" id="login-{{ section.id }}">
  <div class="container">
    <header class="kg3d-page__header"><p class="kg3d-eyebrow">Secure Access</p><h1>Customer Login</h1><p>Access order history, saved addresses, and project details.</p></header>
    <div class="kg3d-auth-grid">
      <div class="kg3d-auth-card">
        {% form 'customer_login' %}
          <h2>Log in</h2>
          {{ form.errors | default_errors }}
          <label for="CustomerEmail">Email</label><input id="CustomerEmail" type="email" name="customer[email]" autocomplete="email" required>
          <label for="CustomerPassword">Password</label><input id="CustomerPassword" type="password" name="customer[password]" autocomplete="current-password" required>
          <button type="submit" class="btn btn-primary">Log In</button>
          <a href="#recover" class="kg3d-link">Forgot password?</a>
        {% endform %}
      </div>
      {% if section.settings.show_signup_form %}
      <div class="kg3d-auth-card">
        {% form 'create_customer' %}
          <h2>Create account</h2>
          {{ form.errors | default_errors }}
          <label for="RegisterFirstName">First name</label><input id="RegisterFirstName" type="text" name="customer[first_name]">
          <label for="RegisterLastName">Last name</label><input id="RegisterLastName" type="text" name="customer[last_name]">
          <label for="RegisterEmail">Email</label><input id="RegisterEmail" type="email" name="customer[email]" required>
          <label for="RegisterPassword">Password</label><input id="RegisterPassword" type="password" name="customer[password]" required>
          <button type="submit" class="btn btn-outline">Create Account</button>
        {% endform %}
      </div>
      {% endif %}
    </div>
    <div id="recover" class="kg3d-auth-card kg3d-recover">
      {% form 'recover_customer_password' %}<h2>Reset password</h2>{{ form.errors | default_errors }}<label for="RecoverEmail">Email</label><input id="RecoverEmail" type="email" name="email" required><button type="submit" class="btn btn-primary">Send reset link</button>{% endform %}
    </div>
  </div>
</section>
<style>.kg3d-page{--kg-bg:#05070d;--kg-panel:rgba(9,14,24,.92);--kg-soft:rgba(13,22,36,.72);--kg-line:rgba(151,195,255,.18);background:radial-gradient(circle at 15% 12%,rgba(0,194,255,.13),transparent 30rem),linear-gradient(rgba(151,195,255,.035) 1px,transparent 1px),linear-gradient(90deg,rgba(151,195,255,.035) 1px,transparent 1px),var(--kg-bg);background-size:auto,52px 52px,52px 52px,auto;color:#f6fbff}.kg3d-page__header{text-align:center;max-width:760px;margin:0 auto 3rem}.kg3d-page__header h1,.kg3d-auth-card h2{color:#f6fbff}.kg3d-page__header p{color:rgba(229,241,255,.68)}.kg3d-eyebrow{letter-spacing:.16em;text-transform:uppercase;color:#7fe7ff;font-weight:800}.kg3d-auth-grid{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:1.5rem}.kg3d-auth-card{background:linear-gradient(145deg,var(--kg-panel),var(--kg-soft));border:1px solid var(--kg-line);border-radius:24px;padding:1.5rem;box-shadow:0 24px 80px rgba(0,0,0,.32)}.kg3d-auth-card form{display:grid;gap:.9rem}.kg3d-auth-card input{background:rgba(255,255,255,.05);border:1px solid var(--kg-line);border-radius:12px;color:#fff;padding:.8rem}.kg3d-link{color:#7fe7ff}.kg3d-recover{margin-top:1.5rem}@media(max-width:800px){.kg3d-auth-grid{grid-template-columns:1fr}}</style>
{% schema %}
{"name":"Main Login","settings":[{"type":"checkbox","id":"show_signup_form","label":"Show signup form","default":true},{"type":"checkbox","id":"show_guest_checkout","label":"Show guest checkout","default":true},{"type":"checkbox","id":"show_social_login","label":"Show social login","default":false}]}
{% endschema %}
