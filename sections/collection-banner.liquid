<section class="section kg3d-page kg3d-collection-banner" id="collection-banner-{{ section.id }}">
  <div class="container kg3d-banner">
    <div>
      <p class="kg3d-eyebrow">Catalog Sector</p>
      <h1>{{ collection.title }}</h1>
      {% if section.settings.show_collection_description and collection.description != blank %}<div class="kg3d-muted">{{ collection.description }}</div>{% endif %}
    </div>
    {% if section.settings.show_collection_image and collection.image %}<div class="kg3d-banner__media">{{ collection.image | image_url: width: 900 | image_tag: loading: 'lazy', widths: '400, 700, 900', sizes: '(min-width: 900px) 40vw, 100vw', alt: collection.title }}</div>{% endif %}
  </div>
</section>
<style>.kg3d-page{--kg-bg:#05070d;--kg-panel:rgba(9,14,24,.92);--kg-line:rgba(151,195,255,.18);background:var(--kg-bg);color:#f6fbff}.kg3d-banner{display:grid;grid-template-columns:1fr minmax(260px,420px);gap:2rem;align-items:center;background:linear-gradient(145deg,var(--kg-panel),rgba(13,22,36,.72));border:1px solid var(--kg-line);border-radius:24px;padding:clamp(1.5rem,4vw,3rem)}.kg3d-banner h1{color:#f6fbff;letter-spacing:-.05em}.kg3d-eyebrow{letter-spacing:.16em;text-transform:uppercase;color:#7fe7ff;font-weight:800}.kg3d-muted{color:rgba(229,241,255,.7)}.kg3d-banner__media{border-radius:20px;overflow:hidden}@media(max-width:800px){.kg3d-banner{grid-template-columns:1fr}}</style>
{% schema %}
{"name":"Collection Banner","settings":[{"type":"checkbox","id":"show_collection_image","label":"Show collection image","default":true},{"type":"checkbox","id":"show_collection_description","label":"Show collection description","default":true}]}
{% endschema %}
