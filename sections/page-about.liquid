  page-about.liquid â€” About page for The Doggie Oreo / KG3D store
{%- endcomment -%}

{%- style -%}
  .kg-about {
    color: #f4f4f5;
    font-family: 'Space Grotesk', sans-serif;
  }

  /* â”€â”€ Hero banner â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ */
  .kg-about__hero {
    position: relative;
    background: linear-gradient(135deg, #05070d 0%, #0a1220 60%, #04060b 100%);
    overflow: hidden;
    padding: clamp(5rem, 10vw, 9rem) clamp(1.5rem, 5vw, 6rem);
    text-align: center;
  }

  .kg-about__hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(244,244,245,0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(244,244,245,0.04) 1px, transparent 1px);
    background-size: 40px 40px;
    pointer-events: none;
  }

  .kg-about__hero::after {
    content: '';
    position: absolute;
    top: -20%; left: 50%;
    transform: translateX(-50%);
    width: 70%; height: 80%;
    background: radial-gradient(ellipse at center, rgba(0,102,255,0.18) 0%, transparent 65%);
    pointer-events: none;
  }

  .kg-about__hero-inner {
    position: relative;
    z-index: 2;
    max-width: 760px;
    margin: 0 auto;
  }

  .kg-about__eyebrow {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.875rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #0066ff;
    background: rgba(0,102,255,0.1);
    border: 1px solid #0066ff;
    display: inline-block;
    padding: 0.45rem 1.1rem;
    border-radius: 4px;
    margin-bottom: 2rem;
  }

  .kg-about__hero-heading {
    font-family: 'Space Grotesk', sans-serif;
    font-size: clamp(2.8rem, 6vw, 5rem);
    font-weight: 800;
    line-height: 1.08;
    text-transform: uppercase;
    letter-spacing: -0.02em;
    color: #ffffff;
    margin: 0 0 1.5rem;
  }

  .kg-about__hero-sub {
    font-size: clamp(1.1rem, 1.5vw + 0.5rem, 1.4rem);
    line-height: 1.65;
    color: rgba(244,244,245,0.72);
    max-width: 580px;
    margin: 0 auto;
  }

  /* â”€â”€ Story section â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ */
  .kg-about__story {
    max-width: 1200px;
    margin: 0 auto;
    padding: clamp(4rem, 8vw, 7rem) clamp(1.5rem, 5vw, 6rem);
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(3rem, 5vw, 6rem);
    align-items: center;
  }

  .kg-about__story-text h2 {
    font-size: clamp(1.8rem, 3vw, 2.8rem);
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: -0.02em;
    color: #ffffff;
    margin: 0 0 1.5rem;
    line-height: 1.1;
  }

  .kg-about__story-text h2 span {
    color: #0066ff;
  }

  .kg-about__story-text p {
    font-size: 1.05rem;
    line-height: 1.75;
    color: rgba(244,244,245,0.75);
    margin: 0 0 1.25rem;
  }

  .kg-about__story-image {
    position: relative;
    border-radius: 12px;
    overflow: hidden;
    border: 1px solid rgba(0,102,255,0.22);
    box-shadow: 0 24px 60px rgba(0,0,0,0.5), 0 0 80px rgba(0,102,255,0.08);
    aspect-ratio: 4 / 3;
    background: rgba(9,9,11,0.5);
  }

  .kg-about__story-image img {
    width: 100%; height: 100%;
    object-fit: cover;
    display: block;
  }

  .kg-about__story-image-placeholder {
    width: 100%; height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.8rem;
    color: rgba(244,244,245,0.3);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    background: linear-gradient(135deg, rgba(0,102,255,0.06), rgba(0,0,0,0.2));
    min-height: 280px;
  }

  /* â”€â”€ Values cards â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ */
  .kg-about__values {
    background: linear-gradient(180deg, rgba(0,102,255,0.04) 0%, transparent 100%);
    border-top: 1px solid rgba(244,244,245,0.06);
    border-bottom: 1px solid rgba(244,244,245,0.06);
    padding: clamp(4rem, 7vw, 6rem) clamp(1.5rem, 5vw, 6rem);
  }

  .kg-about__values-inner {
    max-width: 1200px;
    margin: 0 auto;
  }

  .kg-about__section-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.8rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #0066ff;
    margin-bottom: 1rem;
  }

  .kg-about__values-heading {
    font-size: clamp(1.8rem, 3vw, 2.6rem);
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: -0.02em;
    color: #ffffff;
    margin: 0 0 3rem;
    line-height: 1.1;
  }

  .kg-about__values-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .kg-about__value-card {
    background: rgba(9,9,11,0.55);
    backdrop-filter: blur(12px);
    border: 1px solid rgba(244,244,245,0.08);
    border-radius: 10px;
    padding: 2rem 1.75rem;
    transition: border-color 0.25s ease, transform 0.25s ease, box-shadow 0.25s ease;
  }

  .kg-about__value-card:hover {
    border-color: rgba(0,102,255,0.4);
    transform: translateY(-4px);
    box-shadow: 0 16px 40px rgba(0,0,0,0.3);
  }

  .kg-about__value-icon {
    font-size: 2rem;
    margin-bottom: 1rem;
    display: block;
  }

  .kg-about__value-title {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: #0066ff;
    margin: 0 0 0.6rem;
    font-weight: 700;
  }

  .kg-about__value-text {
    font-size: 0.95rem;
    line-height: 1.7;
    color: rgba(244,244,245,0.68);
    margin: 0;
  }

  /* â”€â”€ Stats row â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ */
  .kg-about__stats {
    max-width: 1200px;
    margin: 0 auto;
    padding: clamp(4rem, 7vw, 6rem) clamp(1.5rem, 5vw, 6rem);
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2rem;
    text-align: center;
  }

  .kg-about__stat-number {
    font-family: 'JetBrains Mono', monospace;
    font-size: clamp(2.4rem, 4vw, 3.5rem);
    font-weight: 800;
    color: #0066ff;
    line-height: 1;
    margin-bottom: 0.5rem;
  }

  .kg-about__stat-label {
    font-size: 0.9rem;
    color: rgba(244,244,245,0.6);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  /* â”€â”€ CTA â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ */
  .kg-about__cta {
    background: linear-gradient(135deg, #05070d 0%, #0a1220 100%);
    border-top: 1px solid rgba(244,244,245,0.06);
    padding: clamp(4rem, 7vw, 6rem) clamp(1.5rem, 5vw, 6rem);
    text-align: center;
  }

  .kg-about__cta h2 {
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: -0.02em;
    color: #ffffff;
    margin: 0 0 1rem;
  }

  .kg-about__cta p {
    font-size: 1.05rem;
    color: rgba(244,244,245,0.7);
    margin: 0 0 2.5rem;
  }

  .kg-about__cta-btns {
    display: flex;
    gap: 1.25rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .kg-about__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    padding: 1rem 2.25rem;
    border-radius: 8px;
    text-decoration: none;
    transition: all 0.25s cubic-bezier(0.4,0,0.2,1);
  }

  .kg-about__btn--primary {
    background: #0066ff;
    color: #ffffff;
    border: 1px solid transparent;
  }

  .kg-about__btn--primary:hover {
    background: #ffffff;
    color: #09090b;
    transform: translateY(-2px);
    box-shadow: 0 10px 25px rgba(0,102,255,0.3);
  }

  .kg-about__btn--secondary {
    background: rgba(9,9,11,0.55);
    backdrop-filter: blur(10px);
    color: #ffffff;
    border: 1px solid rgba(244,244,245,0.14);
  }

  .kg-about__btn--secondary:hover {
    border-color: #ffffff;
    transform: translateY(-2px);
  }

  /* â”€â”€ Responsive â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ */
  @media screen and (max-width: 989px) {
    .kg-about__story {
      grid-template-columns: 1fr;
    }
    .kg-about__values-grid {
      grid-template-columns: 1fr 1fr;
    }
    .kg-about__stats {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media screen and (max-width: 749px) {
    .kg-about__values-grid {
      grid-template-columns: 1fr;
    }
    .kg-about__stats {
      grid-template-columns: 1fr 1fr;
      gap: 1.5rem;
    }
  }
{%- endstyle -%}

