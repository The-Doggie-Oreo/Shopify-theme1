        </div>
        <div class="kg-about__value-card">
          <span class="kg-about__value-icon">ðŸŒ±</span>
          <p class="kg-about__value-title">Small Biz Pride</p>
          <p class="kg-about__value-text">Every purchase supports a real small business and keeps independent creators doing what they love.</p>
        </div>
      </div>
    </div>
  </div>

  <!-- Stats -->
  <div class="kg-about__stats">
    <div>
      <div class="kg-about__stat-number">500+</div>
      <div class="kg-about__stat-label">Orders Shipped</div>
    </div>
    <div>
      <div class="kg-about__stat-number">100%</div>
      <div class="kg-about__stat-label">Custom-Made</div>
