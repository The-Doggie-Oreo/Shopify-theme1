<section class="section section-portfolio" id="portfolio-{{ section.id }}">
  <div class="container">
    <!-- Section Header -->
    <div class="section-header text-center mb-8">
      {% if section.settings.section_title %}
      <h2 class="section-title animate-fade-in-up">{{ section.settings.section_title }}</h2>
      {% endif %}
      {% if section.settings.section_subtitle %}
      <p class="section-subtitle text-large animate-fade-in-up">{{ section.settings.section_subtitle }}</p>
      {% endif %}
    </div>

    <!-- Portfolio Filters -->
    <div class="portfolio-filters mb-6">
      <button class="filter-btn active" data-filter="all">All Projects</button>
      <button class="filter-btn" data-filter="prototype">Prototypes</button>
      <button class="filter-btn" data-filter="functional">Functional Parts</button>
      <button class="filter-btn" data-filter="artistic">Artistic</button>
      <button class="filter-btn" data-filter="trophy">Trophies</button>
    </div>

    <!-- Advanced Masonry Grid -->
    <div class="portfolio-masonry" id="portfolio-grid">
      {% for block in section.blocks %}
      <article class="portfolio-item {{ block.settings.layout }}" data-category="{{ block.settings.tag | downcase | replace: ' ', '-' }}">
        <!-- Portfolio Image -->
        <div class="portfolio-image-container">
          {% if block.settings.image %}
            <img src="{{ block.settings.image | image_url: '800x' }}" 
                 alt="{{ block.settings.title }}" 
                 class="portfolio-image"
                 loading="lazy">
          {% else %}
            <div class="portfolio-placeholder">
              <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect>
                <circle cx="8.5" cy="8.5" r="1.5"></circle>
                <polyline points="21 15 16 10 5 21"></polyline>
              </svg>
            </div>
          {% endif %}
          
          <!-- Overlay Actions -->
          <div class="portfolio-overlay">
            <div class="portfolio-actions">
              <button class="btn btn-outline btn-sm quick-view-btn" data-project="{{ block.id }}">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path>
                  <circle cx="12" cy="12" r="3"></circle>
                </svg>
                Quick View
              </button>
              <button class="btn btn-primary btn-sm project-details-btn">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path>
                  <polyline points="15 3 21 3 21 9"></polyline>
                  <line x1="10" y1="14" x2="21" y2="3"></line>
                </svg>
                Details
              </button>
            </div>
          </div>
        </div>

        <!-- Portfolio Content -->
        <div class="portfolio-content">
          <div class="portfolio-header">
            <h3 class="portfolio-title">{{ block.settings.title }}</h3>
            {% if block.settings.tag %}
            <span class="portfolio-category">{{ block.settings.tag }}</span>
            {% endif %}
          </div>
          
          {% if block.settings.description %}
          <p class="portfolio-description">{{ block.settings.description }}</p>
          {% endif %}

          <div class="portfolio-meta">
            {% if block.settings.material %}
            <div class="meta-item">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M12 2L2 7v10c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V7l-10-5z"/>
              </svg>
              <span>{{ block.settings.material }}</span>
            </div>
            {% endif %}
            
            {% if block.settings.print_time %}
            <div class="meta-item">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="12" cy="12" r="10"></circle>
                <polyline points="12 6 12 12 16 14"></polyline>
              </svg>
              <span>{{ block.settings.print_time }}</span>
            </div>
            {% endif %}
          </div>

          <div class="portfolio-stats">
            <div class="stat">
              <span class="stat-value">{{ forloop.index | times: 47 }}</span>
              <span class="stat-label">Layers</span>
            </div>
            <div class="stat">
              <span class="stat-value">{{ forloop.index | times: 12 }}g</span>
              <span class="stat-label">Weight</span>
            </div>
            <div class="stat">
              <span class="stat-value">{{ forloop.index | times: 8 }}%</span>
              <span class="stat-label">Infill</span>
            </div>
          </div>
        </div>
      </article>
      {% endfor %}
    </div>

    <!-- Load More Button -->
    <div class="text-center mt-8">
      <button class="btn btn-outline load-more-btn" id="load-more-portfolio">
        Load More Projects
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <polyline points="6 9 12 15 18 9"></polyline>
        </svg>
      </button>
    </div>
  </div>
</section>

<style>
.section-portfolio {
  background-color: var(--bg-secondary);
  position: relative;
}

.section-header {
  max-width: 600px;
  margin: 0 auto;
}

.section-title {
  margin-bottom: 1rem;
  color: var(--text-primary);
}

.section-subtitle {
  color: var(--text-secondary);
  margin-bottom: 0;
}

/* Portfolio Filters */
.portfolio-filters {
  display: flex;
  justify-content: center;
  gap: 0.5rem;
  flex-wrap: wrap;
  margin-bottom: 2rem;
}

.filter-btn {
  padding: 0.5rem 1rem;
  background: transparent;
  border: 2px solid var(--border-color);
  border-radius: var(--radius-md);
  color: var(--text-secondary);
  font-weight: 500;
  cursor: pointer;
  transition: all var(--transition-base);
}

.filter-btn:hover {
  border-color: var(--primary-color);
  color: var(--primary-color);
}

.filter-btn.active {
  background-color: var(--primary-color);
  border-color: var(--primary-color);
  color: var(--text-inverse);
}

/* Advanced Masonry Grid */
.portfolio-masonry {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
  gap: 2rem;
  grid-auto-flow: dense;
}

.portfolio-item {
  background: var(--bg-primary);
  border-radius: var(--radius-xl);
  overflow: hidden;
  box-shadow: var(--shadow-md);
  transition: all var(--transition-base);
  position: relative;
}

.portfolio-item:hover {
  transform: translateY(-8px);
  box-shadow: var(--shadow-2xl);
}

/* Masonry Layout Variations */
.portfolio-item.square {
  grid-row: span 1;
  grid-column: span 1;
}

.portfolio-item.tall {
  grid-row: span 2;
  grid-column: span 1;
}

.portfolio-item.wide {
  grid-row: span 1;
  grid-column: span 2;
}

/* Portfolio Image Container */
.portfolio-image-container {
  position: relative;
  overflow: hidden;
  height: 250px;
}

.portfolio-item.tall .portfolio-image-container {
  height: 520px;
}

.portfolio-item.wide .portfolio-image-container {
  height: 250px;
}

.portfolio-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform var(--transition-slow);
}

.portfolio-item:hover .portfolio-image {
  transform: scale(1.1);
}

.portfolio-placeholder {
  width: 100%;
  height: 100%;
  background: linear-gradient(135deg, var(--primary-light), var(--secondary-color));
  display: flex;
  align-items: center;
  justify-content: center;
  color: rgba(255, 255, 255, 0.8);
}

/* Portfolio Overlay */
.portfolio-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(to bottom, transparent 0%, rgba(0, 0, 0, 0.7) 100%);
  display: flex;
  align-items: flex-end;
  padding: 1.5rem;
  opacity: 0;
  transition: opacity var(--transition-base);
}

.portfolio-item:hover .portfolio-overlay {
  opacity: 1;
}

.portfolio-actions {
  display: flex;
  gap: 0.75rem;
}

.portfolio-actions .btn {
  backdrop-filter: blur(10px);
  background: rgba(255, 255, 255, 0.2);
  border: 1px solid rgba(255, 255, 255, 0.3);
  color: white;
}

.portfolio-actions .btn:hover {
  background: rgba(255, 255, 255, 0.3);
}

/* Portfolio Content */
.portfolio-content {
  padding: 1.5rem;
}

.portfolio-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 1rem;
}

.portfolio-title {
  font-size: 1.25rem;
  font-weight: 600;
  color: var(--text-primary);
  margin: 0;
  line-height: 1.3;
}

.portfolio-category {
  background-color: var(--primary-light);
  color: var(--text-inverse);
  padding: 0.25rem 0.75rem;
  border-radius: var(--radius-sm);
  font-size: 0.75rem;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  white-space: nowrap;
}

.portfolio-description {
  color: var(--text-secondary);
  margin-bottom: 1rem;
  line-height: 1.6;
}

.portfolio-meta {
  display: flex;
  gap: 1rem;
  margin-bottom: 1rem;
  flex-wrap: wrap;
}

.meta-item {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  color: var(--text-secondary);
  font-size: 0.875rem;
}

.meta-item svg {
  flex-shrink: 0;
}

.portfolio-stats {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 0.75rem;
  padding-top: 1rem;
  border-top: 1px solid var(--border-light);
}

.stat {
  text-align: center;
}

.stat-value {
  display: block;
  font-size: 1.125rem;
  font-weight: 700;
  color: var(--primary-color);
  margin-bottom: 0.25rem;
}

.stat-label {
  font-size: 0.75rem;
  color: var(--text-light);
  text-transform: uppercase;
  letter-spacing: 0.05em;
}

/* Load More Button */
.load-more-btn {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
}

/* Responsive Design */
@media (max-width: 1024px) {
  .portfolio-masonry {
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
  }
  
  .portfolio-item.wide {
    grid-column: span 1;
  }
}

@media (max-width: 768px) {
  .portfolio-filters {
    gap: 0.25rem;
  }
  
  .filter-btn {
    padding: 0.375rem 0.75rem;
    font-size: 0.875rem;
  }
  
  .portfolio-masonry {
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }
  
  .portfolio-item.tall {
    grid-row: span 1;
  }
  
  .portfolio-item.wide {
    grid-column: span 1;
  }
  
  .portfolio-image-container {
    height: 200px;
  }
  
  .portfolio-item.tall .portfolio-image-container {
    height: 200px;
  }
  
  .portfolio-header {
    flex-direction: column;
    gap: 0.5rem;
  }
  
  .portfolio-actions {
    flex-direction: column;
    gap: 0.5rem;
  }
  
  .portfolio-actions .btn {
    width: 100%;
    justify-content: center;
  }
}

/* Animation Classes */
.portfolio-item {
  opacity: 0;
  transform: translateY(30px);
  animation: fadeInUp 0.6s ease-out forwards;
}

.portfolio-item:nth-child(1) { animation-delay: 0.1s; }
.portfolio-item:nth-child(2) { animation-delay: 0.2s; }
.portfolio-item:nth-child(3) { animation-delay: 0.3s; }
.portfolio-item:nth-child(4) { animation-delay: 0.4s; }
.portfolio-item:nth-child(5) { animation-delay: 0.5s; }
.portfolio-item:nth-child(6) { animation-delay: 0.6s; }

/* Hidden items for filtering */
.portfolio-item.hidden {
  display: none;
}
</style>

<script>
document.addEventListener('DOMContentLoaded', function() {
  // Portfolio filtering
  const filterButtons = document.querySelectorAll('.filter-btn');
  const portfolioItems = document.querySelectorAll('.portfolio-item');
  
  filterButtons.forEach(button => {
    button.addEventListener('click', function() {
      const filter = this.getAttribute('data-filter');
      
      // Update active button
      filterButtons.forEach(btn => btn.classList.remove('active'));
      this.classList.add('active');
      
      // Filter items
      portfolioItems.forEach(item => {
        if (filter === 'all' || item.getAttribute('data-category') === filter) {
          item.classList.remove('hidden');
          item.style.animation = 'fadeInUp 0.6s ease-out forwards';
        } else {
          item.classList.add('hidden');
        }
      });
    });
  });
  
  // Quick view functionality
  const quickViewButtons = document.querySelectorAll('.quick-view-btn');
  
  quickViewButtons.forEach(button => {
    button.addEventListener('click', function(e) {
      e.stopPropagation();
      const projectId = this.getAttribute('data-project');
      // Implement quick view modal
      console.log('Quick view for project:', projectId);
    });
  });
  
  // Project details functionality
  const detailButtons = document.querySelectorAll('.project-details-btn');
  
  detailButtons.forEach(button => {
    button.addEventListener('click', function(e) {
      e.stopPropagation();
      const portfolioItem = this.closest('.portfolio-item');
      const title = portfolioItem.querySelector('.portfolio-title').textContent;
      // Navigate to project details or open modal
      console.log('View details for:', title);
    });
  });
  
  // Load more functionality
  const loadMoreBtn = document.getElementById('load-more-portfolio');
  
  if (loadMoreBtn) {
    loadMoreBtn.addEventListener('click', function() {
      // Simulate loading more items
      this.innerHTML = '<span class="loading-spinner"></span> Loading...';
      
      setTimeout(() => {
        this.innerHTML = 'Load More Projects <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"></polyline></svg>';
        // In a real implementation, you would load and append new portfolio items here
        console.log('Loading more portfolio items...');
      }, 1500);
    });
  }
  
  // Intersection Observer for lazy loading animations
  const observerOptions = {
    threshold: 0.1,
    rootMargin: '0px 0px -50px 0px'
  };
  
  const observer = new IntersectionObserver(function(entries) {
    entries.forEach(entry => {
      if (entry.isIntersecting && !entry.target.classList.contains('animated')) {
        entry.target.classList.add('animated');
        observer.unobserve(entry.target);
      }
    });
  }, observerOptions);
  
  portfolioItems.forEach(item => {
    observer.observe(item);
  });
});
</script>

{% schema %}
{
  "name": "Advanced Portfolio Section",
  "blocks": [
    {
      "type": "portfolio_item",
      "name": "Portfolio Project",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Project Title",
          "default": "Project Title"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Project Image"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Project Description",
          "default": "Brief description of the 3D printing project and its purpose."
        },
        {
          "type": "text",
          "id": "tag",
          "label": "Category",
          "default": "Prototype"
        },
        {
          "type": "select",
          "id": "layout",
          "label": "Layout Size",
          "options": [
            {"value": "square", "label": "Square"},
            {"value": "wide", "label": "Wide"},
            {"value": "tall", "label": "Tall"}
          ],
          "default": "square"
        },
        {
          "type": "text",
          "id": "material",
          "label": "Material Used",
          "default": "PLA"
        },
        {
          "type": "text",
          "id": "print_time",
          "label": "Print Time",
          "default": "12h"
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "text",
      "id": "section_title",
      "label": "Section Title",
      "default": "The Workshop"
    },
    {
      "type": "textarea",
      "id": "section_subtitle",
      "label": "Section Subtitle",
      "default": "Trophies, prototypes, and production runs — all born from filament and resin."
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "label": "Columns on Desktop",
      "min": 2,
      "max": 4,
      "step": 1,
      "default": 3
    },
    {
      "type": "range",
      "id": "gap",
      "label": "Gap Between Items",
      "min": 8,
      "max": 32,
      "step": 4,
      "default": 16,
      "unit": "px"
    }
  ],
  "presets": [
    {
      "name": "Advanced Portfolio",
      "category": "Portfolio",
      "blocks": [
        {
          "type": "portfolio_item",
          "settings": {
            "title": "Drone Housing v3",
            "tag": "Prototype",
            "layout": "tall",
            "material": "PETG",
            "print_time": "18h"
          }
        },
        {
          "type": "portfolio_item",
          "settings": {
            "title": "Architectural Model",
            "tag": "Scale Model",
            "layout": "wide",
            "material": "PLA",
            "print_time": "42h"
          }
        },
        {
          "type": "portfolio_item",
          "settings": {
            "title": "Custom Trophy",
            "tag": "Trophy",
            "layout": "square",
            "material": "Resin",
            "print_time": "8h"
          }
        }
      ]
    }
  ]
}
{% endschema %}