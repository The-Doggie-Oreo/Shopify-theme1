{%- comment -%} page-trophy-order.liquid {%- endcomment -%}
<style>
  .kgt { color: #f4f4f5; font-family: 'Space Grotesk', sans-serif; }

  /* HERO */
  .kgt-hero {
    position: relative;
    background: linear-gradient(135deg, #05070d 0%, #0a1220 60%, #04060b 100%);
    overflow: hidden;
    padding: clamp(6rem, 12vw, 11rem) clamp(2rem, 6vw, 8rem);
    text-align: center;
  }
  .kgt-hero::before {
    content: ''; position: absolute; inset: 0;
    background-image:
      linear-gradient(rgba(244,244,245,0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(244,244,245,0.04) 1px, transparent 1px);
    background-size: 40px 40px; pointer-events: none;
  }
  .kgt-hero::after {
    content: ''; position: absolute; top: -20%; left: 50%; transform: translateX(-50%);
    width: 70%; height: 80%;
    background: radial-gradient(ellipse at center, rgba(0,102,255,0.16) 0%, transparent 65%);
    pointer-events: none;
  }
  .kgt-hero-inner { position: relative; z-index: 2; max-width: 820px; margin: 0 auto; }
  .kgt-badge {
    font-family: 'JetBrains Mono', monospace; font-size: 1rem;
    letter-spacing: 0.18em; text-transform: uppercase;
    color: #0066ff; background: rgba(0,102,255,0.1); border: 1px solid #0066ff;
    display: inline-block; padding: 0.6rem 1.4rem; border-radius: 4px; margin-bottom: 2.5rem;
  }
  .kgt-hero h1 {
    font-family: 'Space Grotesk', sans-serif;
    font-size: clamp(3rem, 6.5vw, 5.5rem); font-weight: 800;
    line-height: 1.06; text-transform: uppercase; letter-spacing: -0.02em;
    color: #ffffff; margin: 0 0 2rem;
  }
  .kgt-hero p {
    font-size: clamp(1.2rem, 1.8vw, 1.55rem);
    line-height: 1.7; color: rgba(244,244,245,0.75);
    max-width: 640px; margin: 0 auto;
  }

  /* STEPS */
  .kgt-section { max-width: 1100px; margin: 0 auto; padding: clamp(5rem, 9vw, 8rem) clamp(2rem, 6vw, 8rem); }
  .kgt-label { font-family: 'JetBrains Mono', monospace; font-size: 0.9rem; letter-spacing: 0.18em; text-transform: uppercase; color: #0066ff; margin-bottom: 0.75rem; }
  .kgt-heading { font-size: clamp(2rem, 3.5vw, 3rem); font-weight: 800; text-transform: uppercase; letter-spacing: -0.02em; color: #ffffff; margin: 0 0 3.5rem; line-height: 1.08; }

  .kgt-steps { display: flex; flex-direction: column; position: relative; }
  .kgt-steps::before {
    content: ''; position: absolute;
    left: 2.5rem; top: 5rem; bottom: 4rem; width: 2px;
    background: linear-gradient(180deg, #0066ff, rgba(0,102,255,0.06));
  }
  .kgt-step { display: grid; grid-template-columns: 5rem 1fr; gap: 2.5rem; align-items: flex-start; padding-bottom: 3.5rem; position: relative; }
  .kgt-step:last-child { padding-bottom: 0; }
  .kgt-step-num {
    width: 5rem; height: 5rem; border-radius: 50%;
    background: rgba(9,9,11,0.95); border: 2px solid #0066ff;
    display: flex; align-items: center; justify-content: center;
    font-family: 'JetBrains Mono', monospace; font-size: 1.3rem; font-weight: 800; color: #0066ff;
    flex-shrink: 0; box-shadow: 0 0 28px rgba(0,102,255,0.25); z-index: 1; position: relative;
  }
  .kgt-step-body {
    background: rgba(9,9,11,0.5); backdrop-filter: blur(12px);
    border: 1px solid rgba(244,244,245,0.09); border-radius: 12px;
    padding: 2rem 2.25rem;
    transition: border-color 0.25s ease, box-shadow 0.25s ease;
  }
  .kgt-step-body:hover { border-color: rgba(0,102,255,0.4); box-shadow: 0 16px 40px rgba(0,0,0,0.3); }
  .kgt-step-tag { font-family: 'JetBrains Mono', monospace; font-size: 0.82rem; text-transform: uppercase; letter-spacing: 0.14em; color: #0066ff; margin: 0 0 0.5rem; font-weight: 700; }
  .kgt-step-title { font-size: clamp(1.2rem, 1.6vw, 1.45rem); font-weight: 700; color: #ffffff; margin: 0 0 0.75rem; line-height: 1.3; }
  .kgt-step-text { font-size: clamp(1rem, 1.2vw, 1.15rem); line-height: 1.85; color: rgba(244,244,245,0.75); margin: 0; }
  .kgt-step-text a { color: #0066ff; text-decoration: underline; text-underline-offset: 3px; }

  /* INFO BAND */
  .kgt-band {
    background: rgba(0,102,255,0.03);
    border-top: 1px solid rgba(244,244,245,0.06);
    border-bottom: 1px solid rgba(244,244,245,0.06);
    padding: clamp(5rem, 8vw, 7rem) clamp(2rem, 6vw, 8rem);
  }
  .kgt-band-inner { max-width: 1100px; margin: 0 auto; }
  .kgt-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.75rem; margin-top: 3.5rem; }
  .kgt-card {
    background: rgba(9,9,11,0.6); backdrop-filter: blur(12px);
    border: 1px solid rgba(244,244,245,0.08); border-radius: 12px; padding: 2rem 1.75rem;
    transition: border-color 0.25s ease, transform 0.25s ease;
  }
  .kgt-card:hover { border-color: rgba(0,102,255,0.4); transform: translateY(-4px); }
  .kgt-card-icon { font-size: 2.2rem; margin-bottom: 1rem; display: block; }
  .kgt-card-title { font-family: 'JetBrains Mono', monospace; font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.12em; color: #0066ff; margin: 0 0 0.65rem; font-weight: 700; }
  .kgt-card-text { font-size: 1.05rem; line-height: 1.8; color: rgba(244,244,245,0.72); margin: 0; }

  /* TIMELINE BAND */
  .kgt-timeline {
    max-width: 1100px; margin: 0 auto;
    padding: 0 clamp(2rem, 6vw, 8rem) clamp(5rem, 8vw, 7rem);
  }
  .kgt-timeline-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 0; margin-top: 3.5rem; position: relative; }
  .kgt-timeline-grid::before {
    content: ''; position: absolute; top: 2.5rem; left: 12.5%; right: 12.5%; height: 2px;
    background: linear-gradient(90deg, #0066ff, rgba(0,102,255,0.2));
  }
  .kgt-tl-item { text-align: center; padding: 0 1rem; position: relative; }
  .kgt-tl-dot {
    width: 5rem; height: 5rem; border-radius: 50%;
    background: rgba(9,9,11,0.9); border: 2px solid #0066ff;
    display: flex; align-items: center; justify-content: center;
    margin: 0 auto 1.25rem; font-size: 1.6rem;
    box-shadow: 0 0 24px rgba(0,102,255,0.2); position: relative; z-index: 1;
  }
  .kgt-tl-title { font-family: 'JetBrains Mono', monospace; font-size: 0.82rem; text-transform: uppercase; letter-spacing: 0.1em; color: #0066ff; margin-bottom: 0.5rem; font-weight: 700; }
  .kgt-tl-text { font-size: 1rem; color: rgba(244,244,245,0.65); line-height: 1.6; }

  /* FAQ */
  .kgt-faq-wrap { max-width: 860px; margin: 0 auto; padding: clamp(5rem, 8vw, 7rem) clamp(2rem, 6vw, 8rem); }
  .kgt-faq-list { display: flex; flex-direction: column; gap: 1.1rem; margin-top: 3.5rem; }
  .kgt-faq-item { background: rgba(9,9,11,0.5); border: 1px solid rgba(244,244,245,0.09); border-radius: 10px; overflow: hidden; transition: border-color 0.2s ease; }
  .kgt-faq-item.open { border-color: rgba(0,102,255,0.3); }
  .kgt-faq-q {
    width: 100%; text-align: left; background: none; border: none;
    color: #ffffff; font-family: 'Space Grotesk', sans-serif;
    font-size: clamp(1rem, 1.3vw, 1.2rem); font-weight: 600;
    padding: 1.5rem 1.75rem; cursor: pointer;
    display: flex; justify-content: space-between; align-items: center; gap: 1rem;
    transition: color 0.2s ease;
  }
  .kgt-faq-q:hover { color: #0066ff; }
  .kgt-faq-icon { flex-shrink: 0; font-family: 'JetBrains Mono', monospace; font-size: 1.4rem; color: #0066ff; transition: transform 0.25s ease; line-height: 1; }
  .kgt-faq-item.open .kgt-faq-icon { transform: rotate(45deg); }
  .kgt-faq-a { display: none; padding: 0 1.75rem 1.5rem; font-size: clamp(1rem, 1.2vw, 1.1rem); line-height: 1.85; color: rgba(244,244,245,0.75); }
  .kgt-faq-item.open .kgt-faq-a { display: block; }

  /* CTA */
  .kgt-cta {
    background: linear-gradient(135deg, #05070d 0%, #0a1220 100%);
    border-top: 1px solid rgba(244,244,245,0.06);
    padding: clamp(5rem, 9vw, 8rem) clamp(2rem, 6vw, 8rem);
    text-align: center;
  }
  .kgt-cta h2 { font-size: clamp(2.2rem, 4.5vw, 3.6rem); font-weight: 800; text-transform: uppercase; letter-spacing: -0.02em; color: #ffffff; margin: 0 0 1.25rem; }
  .kgt-cta p { font-size: clamp(1.1rem, 1.5vw, 1.35rem); color: rgba(244,244,245,0.72); margin: 0 0 3rem; }
  .kgt-cta-btns { display: flex; gap: 1.5rem; justify-content: center; flex-wrap: wrap; }
  .kgt-btn {
    display: inline-flex; align-items: center; justify-content: center;
    font-family: 'JetBrains Mono', monospace; font-size: 1rem; font-weight: 700;
    text-transform: uppercase; letter-spacing: 0.1em;
    padding: 1.15rem 2.75rem; border-radius: 8px; text-decoration: none;
    transition: all 0.25s cubic-bezier(0.4,0,0.2,1);
  }
  .kgt-btn--primary { background: #0066ff; color: #ffffff; border: 1px solid transparent; }
  .kgt-btn--primary:hover { background: #ffffff; color: #09090b; transform: translateY(-2px); box-shadow: 0 12px 30px rgba(0,102,255,0.35); }
  .kgt-btn--secondary { background: rgba(9,9,11,0.6); backdrop-filter: blur(10px); color: #ffffff; border: 1px solid rgba(244,244,245,0.18); }
  .kgt-btn--secondary:hover { border-color: #ffffff; transform: translateY(-2px); }

  /* RESPONSIVE */
  @media screen and (max-width: 989px) {
    .kgt-grid { grid-template-columns: 1fr 1fr; }
    .kgt-timeline-grid { grid-template-columns: 1fr 1fr; gap: 2rem; }
    .kgt-timeline-grid::before { display: none; }
  }
  @media screen and (max-width: 749px) {
    .kgt-steps::before { display: none; }
    .kgt-step { grid-template-columns: 1fr; gap: 1rem; }
    .kgt-step-num { width: 4rem; height: 4rem; font-size: 1.1rem; }
    .kgt-grid { grid-template-columns: 1fr; }
    .kgt-timeline-grid { grid-template-columns: 1fr 1fr; }
  }
</style>

<div class="kgt">

  <!-- HERO -->
  <div class="kgt-hero">
    <div class="kgt-hero-inner">
      <span class="kgt-badge">Custom Orders</span>
      <h1>How to Order<br>a Custom Trophy</h1>
      <p>Ordering a personalised trophy or award is simple. Follow the steps below and we will handle everything else from start to finish.</p>
    </div>
  </div>

  <!-- STEPS -->
  <div class="kgt-section">
    <p class="kgt-label">Step-by-Step Guide</p>
    <h2 class="kgt-heading">The Order Process</h2>
    <div class="kgt-steps">

      <div class="kgt-step">
        <div class="kgt-step-num">01</div>
        <div class="kgt-step-body">
          <p class="kgt-step-tag">Step 1</p>
          <h3 class="kgt-step-title">Choose Your Trophy Style</h3>
          <p class="kgt-step-text">Browse our <a href="/collections/all">trophy collection</a> and pick the style, size, and design that fits your event or recipient. Read the product descriptions carefully -- they include guidance on what each trophy is best suited for, sizing information, and material details.</p>
        </div>
      </div>

      <div class="kgt-step">
        <div class="kgt-step-num">02</div>
        <div class="kgt-step-body">
          <p class="kgt-step-tag">Step 2</p>
          <h3 class="kgt-step-title">Select Your Options</h3>
          <p class="kgt-step-text">On the product page, choose any available options such as size, colour, or finish. If there is a personalisation field shown, enter the text you want engraved or printed -- for example the winner name, event name, date, or a short message. Keep text concise for best results.</p>
        </div>
      </div>

      <div class="kgt-step">
        <div class="kgt-step-num">03</div>
        <div class="kgt-step-body">
          <p class="kgt-step-tag">Step 3</p>
          <h3 class="kgt-step-title">Add Full Personalisation Details at Checkout</h3>
          <p class="kgt-step-text">In the order notes field at checkout, include any special instructions -- custom text, preferred fonts, logo requests, colour preferences, or anything specific to your vision. The more detail you give us the better we can match exactly what you want. You can also <a href="/pages/contact">contact us</a> before ordering if you have questions.</p>
        </div>
      </div>

      <div class="kgt-step">
        <div class="kgt-step-num">04</div>
        <div class="kgt-step-body">
          <p class="kgt-step-tag">Step 4</p>
          <h3 class="kgt-step-title">Complete Your Purchase Securely</h3>
          <p class="kgt-step-text">Proceed to checkout and complete your payment. We accept all major credit and debit cards, PayPal, and other available payment methods. You will receive an order confirmation email immediately after placing your order.</p>
        </div>
      </div>

      <div class="kgt-step">
        <div class="kgt-step-num">05</div>
        <div class="kgt-step-body">
          <p class="kgt-step-tag">Step 5</p>
          <h3 class="kgt-step-title">We Review and Confirm Your Design</h3>
          <p class="kgt-step-text">Once we receive your order we review every personalisation detail carefully. If anything needs clarifying -- a typo, an unclear instruction, or a design question -- we will contact you by email within 1 business day before production starts. We never begin making your trophy until we are confident the details are right.</p>
        </div>
      </div>

      <div class="kgt-step">
        <div class="kgt-step-num">06</div>
        <div class="kgt-step-body">
          <p class="kgt-step-tag">Step 6</p>
          <h3 class="kgt-step-title">Production and Quality Inspection</h3>
          <p class="kgt-step-text">Your trophy is made to order -- we do not keep generic pre-made stock. Production typically takes 3 to 5 business days depending on complexity. Every finished item goes through a thorough quality inspection before it is packed. We do not ship anything we would not be proud to display ourselves.</p>
        </div>
      </div>

      <div class="kgt-step">
        <div class="kgt-step-num">07</div>
        <div class="kgt-step-body">
          <p class="kgt-step-tag">Step 7</p>
          <h3 class="kgt-step-title">Carefully Packed and Shipped to Your Door</h3>
          <p class="kgt-step-text">Your order is packed securely to protect it in transit, then dispatched with full tracking. You will receive a shipping confirmation email with your tracking number as soon as it leaves us. Standard delivery is 3 to 7 business days after dispatch depending on your location. International orders are welcome.</p>
        </div>
      </div>

    </div>
  </div>

  <!-- TIMELINE -->
  <div class="kgt-band">
    <div class="kgt-band-inner">
      <p class="kgt-label">At a Glance</p>
      <h2 class="kgt-heading">Your Order Timeline</h2>
      <div class="kgt-timeline-grid">
        <div class="kgt-tl-item">
          <div class="kgt-tl-dot">&#128722;</div>
          <div class="kgt-tl-title">Day 1</div>
          <div class="kgt-tl-text">Order placed and confirmed by email</div>
        </div>
        <div class="kgt-tl-item">
          <div class="kgt-tl-dot">&#9998;&#65039;</div>
          <div class="kgt-tl-title">Day 1-2</div>
          <div class="kgt-tl-text">Design reviewed and confirmed with you</div>
        </div>
        <div class="kgt-tl-item">
          <div class="kgt-tl-dot">&#128736;&#65039;</div>
          <div class="kgt-tl-title">Day 2-6</div>
          <div class="kgt-tl-text">Production and quality inspection</div>
        </div>
        <div class="kgt-tl-item">
          <div class="kgt-tl-dot">&#128230;</div>
          <div class="kgt-tl-title">Day 6-13</div>
          <div class="kgt-tl-text">Dispatched with tracking to your door</div>
        </div>
      </div>
    </div>
  </div>

  <!-- INFO CARDS -->
  <div class="kgt-section" style="padding-top: clamp(5rem, 8vw, 7rem);">
    <p class="kgt-label">Good to Know</p>
    <h2 class="kgt-heading">Important Information</h2>
    <div class="kgt-grid" style="margin-top: 0;">
      <div class="kgt-card">
        <span class="kgt-card-icon">&#9201;&#65039;</span>
        <p class="kgt-card-title">Production Time</p>
        <p class="kgt-card-text">Custom orders take 3 to 5 business days to produce after design confirmation. Add 3 to 7 days for shipping. Order at least 2 weeks before your event to be safe.</p>
      </div>
      <div class="kgt-card">
        <span class="kgt-card-icon">&#128260;</span>
        <p class="kgt-card-title">Changes and Cancellations</p>
        <p class="kgt-card-text">You can modify or cancel your order within 24 hours of placing it, before production begins. After production starts we cannot accept cancellations. Contact us immediately if you need to make a change.</p>
      </div>
      <div class="kgt-card">
        <span class="kgt-card-icon">&#127942;</span>
        <p class="kgt-card-title">Bulk and Team Orders</p>
        <p class="kgt-card-text">Need 5 or more trophies for a tournament, league, or team? Contact us before ordering for bulk pricing. We will put together a custom quote and ensure consistent quality across every piece.</p>
      </div>
      <div class="kgt-card">
        <span class="kgt-card-icon">&#128444;&#65039;</span>
        <p class="kgt-card-title">Logo and Image Requests</p>
        <p class="kgt-card-text">Want your team logo or a custom image on the trophy? Send us the file -- PNG or SVG preferred, high resolution -- via the order notes at checkout or email us directly before ordering.</p>
      </div>
      <div class="kgt-card">
        <span class="kgt-card-icon">&#9989;</span>
        <p class="kgt-card-title">Quality Guarantee</p>
        <p class="kgt-card-text">If your trophy arrives damaged or does not match what was agreed, we will replace it at no cost to you. Simply contact us with a photo within 7 days of receiving your order. No questions, no hassle.</p>
      </div>
      <div class="kgt-card">
        <span class="kgt-card-icon">&#128172;</span>
        <p class="kgt-card-title">Questions Before Ordering?</p>
        <p class="kgt-card-text">Not sure about something? Reach out before you order. We respond within 24 hours and are genuinely happy to help you plan and design the perfect custom trophy for your event or occasion.</p>
      </div>
    </div>
  </div>

  <!-- FAQ -->
  <div class="kgt-faq-wrap">
    <p class="kgt-label">FAQ</p>
    <h2 class="kgt-heading">Common Questions</h2>
    <div class="kgt-faq-list">

      <div class="kgt-faq-item">
        <button class="kgt-faq-q" aria-expanded="false">
          Can I see a preview of my trophy before it is made?
          <span class="kgt-faq-icon">+</span>
        </button>
        <div class="kgt-faq-a">For complex custom designs involving logos, multiple lines of text, or specific layouts, we will send you a digital proof via email before production begins. For straightforward text engravings we will proceed directly from your order notes, but you are always welcome to request a proof.</div>
      </div>

      <div class="kgt-faq-item">
        <button class="kgt-faq-q" aria-expanded="false">
          What if I make a spelling mistake in the personalisation?
          <span class="kgt-faq-icon">+</span>
        </button>
        <div class="kgt-faq-a">If you spot a mistake after ordering, contact us immediately. We review every order before starting production and will always double-check spelling and details with you. If a mistake slips through on our side we will redo it at no charge. If the error was in the original order notes we will do our best to work something out.</div>
      </div>

      <div class="kgt-faq-item">
        <button class="kgt-faq-q" aria-expanded="false">
          Do you ship internationally?
          <span class="kgt-faq-icon">+</span>
        </button>
        <div class="kgt-faq-a">Yes, we ship worldwide. International delivery times vary depending on your destination and the shipping method selected at checkout. Please note that customs fees and import duties if applicable are the responsibility of the buyer. We always include accurate customs declarations on international parcels.</div>
      </div>

      <div class="kgt-faq-item">
        <button class="kgt-faq-q" aria-expanded="false">
          How far in advance should I order for a specific event?
          <span class="kgt-faq-icon">+</span>
        </button>
        <div class="kgt-faq-a">We strongly recommend ordering at least 2 weeks before your event date. This allows time for production (3 to 5 days), shipping (3 to 7 days), and a small buffer for any back-and-forth on design details. For bulk orders of 5 or more trophies, or complex designs, please allow at least 3 weeks.</div>
      </div>

      <div class="kgt-faq-item">
        <button class="kgt-faq-q" aria-expanded="false">
          What materials are the trophies made from?
          <span class="kgt-faq-icon">+</span>
        </button>
        <div class="kgt-faq-a">Materials vary depending on the specific product -- check the individual product pages for full details. Most of our trophies and awards are made from high-quality resin, acrylic, or precision-printed PLA and PETG filament with a durable finished surface. We choose materials that look great and hold up over time.</div>
      </div>

      <div class="kgt-faq-item">
        <button class="kgt-faq-q" aria-expanded="false">
          Can I order trophies for a gaming tournament or esports event?
          <span class="kgt-faq-icon">+</span>
        </button>
        <div class="kgt-faq-a">Absolutely -- this is exactly what we specialise in. We can incorporate game logos, controller designs, team names, player tags, placement text, and more. Whether it is a local LAN party or a full esports bracket event, contact us to discuss your vision and we will make it happen.</div>
      </div>

      <div class="kgt-faq-item">
        <button class="kgt-faq-q" aria-expanded="false">
          Is there a minimum order quantity?
          <span class="kgt-faq-icon">+</span>
        </button>
        <div class="kgt-faq-a">No minimum -- you can order just one trophy if that is all you need. We treat every single order with the same care regardless of quantity. For bulk orders of 5 or more we offer better pricing so contact us first to get a quote.</div>
      </div>

    </div>
  </div>

  <!-- CTA -->
  <div class="kgt-cta">
    <h2>Ready to Order?</h2>
    <p>Browse our trophy range or get in touch -- we are happy to help you design something truly custom.</p>
    <div class="kgt-cta-btns">
      <a href="/collections/all" class="kgt-btn kgt-btn--primary">Shop Trophies</a>
      <a href="/pages/contact" class="kgt-btn kgt-btn--secondary">Contact Us</a>
    </div>
  </div>

</div>

<script>
  document.querySelectorAll('.kgt-faq-q').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var item = btn.closest('.kgt-faq-item');
      var isOpen = item.classList.contains('open');
      document.querySelectorAll('.kgt-faq-item').forEach(function(i) { i.classList.remove('open'); });
      if (!isOpen) item.classList.add('open');
      btn.setAttribute('aria-expanded', String(!isOpen));
    });
  });
</script>

{% schema %}
{
  "name": "Trophy Order Guide",
  "tag": "section",
  "class": "section",
  "settings": [],
  "presets": [{ "name": "Trophy Order Guide" }]
}
{% endschema %}
