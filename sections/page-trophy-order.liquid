{%- comment -%} page-trophy-order.liquid {%- endcomment -%}
<style>
  .kgt { color: #f4f4f5; font-family: 'Space Grotesk', sans-serif; }

  /* HERO */
  .kgt-hero {
    position: relative;
    background: linear-gradient(135deg, #05070d 0%, #0a1220 60%, #04060b 100%);
    overflow: hidden;
    padding: clamp(5rem, 10vw, 9rem) clamp(1.5rem, 5vw, 6rem);
    text-align: center;
  }
  .kgt-hero::before {
    content: '';
    position: absolute; inset: 0;
    background-image:
      linear-gradient(rgba(244,244,245,0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(244,244,245,0.04) 1px, transparent 1px);
    background-size: 40px 40px;
    pointer-events: none;
  }
  .kgt-hero::after {
    content: '';
    position: absolute;
    top: -20%; left: 50%; transform: translateX(-50%);
    width: 70%; height: 80%;
    background: radial-gradient(ellipse at center, rgba(0,102,255,0.16) 0%, transparent 65%);
    pointer-events: none;
  }
  .kgt-hero-inner { position: relative; z-index: 2; max-width: 720px; margin: 0 auto; }
  .kgt-badge {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.8rem; letter-spacing: 0.18em; text-transform: uppercase;
    color: #0066ff; background: rgba(0,102,255,0.1);
    border: 1px solid #0066ff;
    display: inline-block; padding: 0.45rem 1.1rem; border-radius: 4px; margin-bottom: 2rem;
  }
  .kgt-hero h1 {
    font-family: 'Space Grotesk', sans-serif;
    font-size: clamp(2.6rem, 5.5vw, 4.8rem); font-weight: 800;
    line-height: 1.08; text-transform: uppercase; letter-spacing: -0.02em;
    color: #ffffff; margin: 0 0 1.5rem;
  }
  .kgt-hero p {
    font-size: clamp(1rem, 1.5vw + 0.4rem, 1.3rem);
    line-height: 1.65; color: rgba(244,244,245,0.72);
    max-width: 560px; margin: 0 auto;
  }

  /* STEPS */
  .kgt-section { max-width: 1100px; margin: 0 auto; padding: clamp(4rem, 8vw, 7rem) clamp(1.5rem, 5vw, 6rem); }
  .kgt-label {
    font-family: 'JetBrains Mono', monospace; font-size: 0.78rem;
    letter-spacing: 0.18em; text-transform: uppercase; color: #0066ff; margin-bottom: 0.75rem;
  }
  .kgt-heading {
    font-size: clamp(1.8rem, 3vw, 2.6rem); font-weight: 800;
    text-transform: uppercase; letter-spacing: -0.02em;
    color: #ffffff; margin: 0 0 3.5rem; line-height: 1.1;
  }
  .kgt-steps { display: flex; flex-direction: column; position: relative; }
  .kgt-steps::before {
    content: ''; position: absolute;
    left: 2.2rem; top: 4.5rem; bottom: 4rem; width: 2px;
    background: linear-gradient(180deg, #0066ff, rgba(0,102,255,0.08));
  }
  .kgt-step { display: grid; grid-template-columns: 4.5rem 1fr; gap: 2rem; align-items: flex-start; padding-bottom: 3rem; position: relative; }
  .kgt-step:last-child { padding-bottom: 0; }
  .kgt-step-num {
    width: 4.5rem; height: 4.5rem; border-radius: 50%;
    background: rgba(9,9,11,0.9); border: 2px solid #0066ff;
    display: flex; align-items: center; justify-content: center;
    font-family: 'JetBrains Mono', monospace; font-size: 1.2rem; font-weight: 800; color: #0066ff;
    flex-shrink: 0; box-shadow: 0 0 24px rgba(0,102,255,0.2); z-index: 1; position: relative;
  }
  .kgt-step-body {
    background: rgba(9,9,11,0.5); backdrop-filter: blur(10px);
    border: 1px solid rgba(244,244,245,0.08); border-radius: 10px;
    padding: 1.75rem 2rem;
    transition: border-color 0.25s ease, box-shadow 0.25s ease;
  }
  .kgt-step-body:hover { border-color: rgba(0,102,255,0.4); box-shadow: 0 12px 32px rgba(0,0,0,0.3); }
  .kgt-step-tag { font-family: 'JetBrains Mono', monospace; font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.12em; color: #0066ff; margin: 0 0 0.4rem; font-weight: 700; }
  .kgt-step-title { font-size: 1.2rem; font-weight: 700; color: #ffffff; margin: 0 0 0.6rem; }
  .kgt-step-text { font-size: 0.96rem; line-height: 1.75; color: rgba(244,244,245,0.72); margin: 0; }
  .kgt-step-text a { color: #0066ff; text-decoration: underline; text-underline-offset: 3px; }

  /* INFO CARDS */
  .kgt-band {
    background: rgba(0,102,255,0.03);
    border-top: 1px solid rgba(244,244,245,0.06);
    border-bottom: 1px solid rgba(244,244,245,0.06);
    padding: clamp(4rem, 7vw, 6rem) clamp(1.5rem, 5vw, 6rem);
  }
  .kgt-band-inner { max-width: 1100px; margin: 0 auto; }
  .kgt-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; margin-top: 3rem; }
  .kgt-card {
    background: rgba(9,9,11,0.55); backdrop-filter: blur(12px);
    border: 1px solid rgba(244,244,245,0.08); border-radius: 10px; padding: 1.75rem;
    transition: border-color 0.25s ease, transform 0.25s ease;
  }
  .kgt-card:hover { border-color: rgba(0,102,255,0.35); transform: translateY(-3px); }
  .kgt-card-icon { font-size: 1.75rem; margin-bottom: 0.85rem; display: block; }
  .kgt-card-title { font-family: 'JetBrains Mono', monospace; font-size: 0.78rem; text-transform: uppercase; letter-spacing: 0.12em; color: #0066ff; margin: 0 0 0.5rem; font-weight: 700; }
  .kgt-card-text { font-size: 0.93rem; line-height: 1.7; color: rgba(244,244,245,0.68); margin: 0; }

  /* FAQ */
  .kgt-faq-wrap { max-width: 800px; margin: 0 auto; padding: clamp(4rem, 7vw, 6rem) clamp(1.5rem, 5vw, 6rem); }
  .kgt-faq-list { display: flex; flex-direction: column; gap: 1rem; margin-top: 3rem; }
  .kgt-faq-item { background: rgba(9,9,11,0.45); border: 1px solid rgba(244,244,245,0.08); border-radius: 8px; overflow: hidden; }
  .kgt-faq-q {
    width: 100%; text-align: left; background: none; border: none;
    color: #ffffff; font-family: 'Space Grotesk', sans-serif; font-size: 1rem; font-weight: 600;
    padding: 1.25rem 1.5rem; cursor: pointer;
    display: flex; justify-content: space-between; align-items: center; gap: 1rem;
    transition: color 0.2s ease;
  }
  .kgt-faq-q:hover { color: #0066ff; }
  .kgt-faq-icon { flex-shrink: 0; font-family: 'JetBrains Mono', monospace; font-size: 1.2rem; color: #0066ff; transition: transform 0.2s ease; }
  .kgt-faq-item.open .kgt-faq-icon { transform: rotate(45deg); }
  .kgt-faq-a { display: none; padding: 0 1.5rem 1.25rem; font-size: 0.95rem; line-height: 1.75; color: rgba(244,244,245,0.7); }
  .kgt-faq-item.open .kgt-faq-a { display: block; }

  /* CTA */
  .kgt-cta {
    background: linear-gradient(135deg, #05070d 0%, #0a1220 100%);
    border-top: 1px solid rgba(244,244,245,0.06);
    padding: clamp(4rem, 7vw, 6rem) clamp(1.5rem, 5vw, 6rem);
    text-align: center;
  }
  .kgt-cta h2 { font-size: clamp(2rem, 4vw, 3rem); font-weight: 800; text-transform: uppercase; letter-spacing: -0.02em; color: #ffffff; margin: 0 0 1rem; }
  .kgt-cta p { font-size: 1.05rem; color: rgba(244,244,245,0.7); margin: 0 0 2.5rem; }
  .kgt-cta-btns { display: flex; gap: 1.25rem; justify-content: center; flex-wrap: wrap; }
  .kgt-btn {
    display: inline-flex; align-items: center; justify-content: center;
    font-family: 'JetBrains Mono', monospace; font-size: 0.875rem; font-weight: 700;
    text-transform: uppercase; letter-spacing: 0.1em;
    padding: 1rem 2.25rem; border-radius: 8px; text-decoration: none;
    transition: all 0.25s cubic-bezier(0.4,0,0.2,1);
  }
  .kgt-btn--primary { background: #0066ff; color: #ffffff; border: 1px solid transparent; }
  .kgt-btn--primary:hover { background: #ffffff; color: #09090b; transform: translateY(-2px); box-shadow: 0 10px 25px rgba(0,102,255,0.3); }
  .kgt-btn--secondary { background: rgba(9,9,11,0.55); backdrop-filter: blur(10px); color: #ffffff; border: 1px solid rgba(244,244,245,0.14); }
  .kgt-btn--secondary:hover { border-color: #ffffff; transform: translateY(-2px); }

  /* RESPONSIVE */
  @media screen and (max-width: 989px) { .kgt-grid { grid-template-columns: 1fr 1fr; } }
  @media screen and (max-width: 749px) {
    .kgt-steps::before { display: none; }
    .kgt-step { grid-template-columns: 1fr; }
    .kgt-grid { grid-template-columns: 1fr; }
    .kgt-step-num { width: 3.5rem; height: 3.5rem; font-size: 1rem; }
  }
</style>

<div class="kgt">

  <div class="kgt-hero">
    <div class="kgt-hero-inner">
      <span class="kgt-badge">Custom Orders</span>
      <h1>How to Order<br>a Custom Trophy</h1>
      <p>Ordering a personalised trophy or award is simple. Follow the steps below and we will handle everything else.</p>
    </div>
  </div>

  <div class="kgt-section">
    <p class="kgt-label">Step-by-Step Guide</p>
    <h2 class="kgt-heading">The Order Process</h2>
    <div class="kgt-steps">

      <div class="kgt-step">
        <div class="kgt-step-num">01</div>
        <div class="kgt-step-body">
          <p class="kgt-step-tag">Step 1</p>
          <h3 class="kgt-step-title">Choose Your Trophy Style</h3>
          <p class="kgt-step-text">Browse our <a href="/collections/all">trophy collection</a> and pick the style, size, and design that fits your event or recipient. Check the product descriptions for guidance on what each trophy is best suited for.</p>
        </div>
      </div>

      <div class="kgt-step">
        <div class="kgt-step-num">02</div>
        <div class="kgt-step-body">
          <p class="kgt-step-tag">Step 2</p>
          <h3 class="kgt-step-title">Add to Cart and Select Options</h3>
          <p class="kgt-step-text">On the product page, select any available options such as size, colour, or finish. If there is a personalisation field, enter the text you want engraved or printed -- for example: winner name, event name, date, or a short message.</p>
        </div>
      </div>

      <div class="kgt-step">
        <div class="kgt-step-num">03</div>
        <div class="kgt-step-body">
          <p class="kgt-step-tag">Step 3</p>
          <h3 class="kgt-step-title">Leave Your Personalisation Details</h3>
          <p class="kgt-step-text">In the order notes at checkout, include any special instructions -- custom text, specific fonts, logo requests, or anything else you need. The more detail you give us, the better we can match your vision. You can also <a href="/pages/contact">contact us first</a> if you have questions before ordering.</p>
        </div>
      </div>

      <div class="kgt-step">
        <div class="kgt-step-num">04</div>
        <div class="kgt-step-body">
          <p class="kgt-step-tag">Step 4</p>
          <h3 class="kgt-step-title">Complete Your Purchase</h3>
          <p class="kgt-step-text">Proceed to checkout and complete payment securely. We accept all major credit and debit cards, PayPal, and more. You will receive an order confirmation email straight away.</p>
        </div>
      </div>

      <div class="kgt-step">
        <div class="kgt-step-num">05</div>
        <div class="kgt-step-body">
          <p class="kgt-step-tag">Step 5</p>
          <h3 class="kgt-step-title">We Review and Confirm Your Design</h3>
          <p class="kgt-step-text">Once we receive your order we will review your personalisation details. If anything needs clarifying we will reach out via email within 1 business day before production begins. No surprises.</p>
        </div>
      </div>

      <div class="kgt-step">
        <div class="kgt-step-num">06</div>
        <div class="kgt-step-body">
          <p class="kgt-step-tag">Step 6</p>
          <h3 class="kgt-step-title">Production and Quality Check</h3>
          <p class="kgt-step-text">Your trophy is made to order. Production typically takes 3 to 5 business days. Every item goes through a quality inspection before it is packed -- we do not ship anything we would not be proud to display ourselves.</p>
        </div>
      </div>

      <div class="kgt-step">
        <div class="kgt-step-num">07</div>
        <div class="kgt-step-body">
          <p class="kgt-step-tag">Step 7</p>
          <h3 class="kgt-step-title">Shipped to Your Door</h3>
          <p class="kgt-step-text">Your order is carefully packaged and dispatched with tracking. You will receive a shipping confirmation email with your tracking number. Standard delivery is 3 to 7 business days after dispatch depending on your location.</p>
        </div>
      </div>

    </div>
  </div>

  <div class="kgt-band">
    <div class="kgt-band-inner">
      <p class="kgt-label">Good to Know</p>
      <h2 class="kgt-heading">Important Info</h2>
      <div class="kgt-grid">
        <div class="kgt-card">
          <span class="kgt-card-icon">&#9201;</span>
          <p class="kgt-card-title">Production Time</p>
          <p class="kgt-card-text">Custom orders take 3 to 5 business days to produce after design confirmation, plus shipping time. Plan ahead for events.</p>
        </div>
        <div class="kgt-card">
          <span class="kgt-card-icon">&#128260;</span>
          <p class="kgt-card-title">Changes and Cancellations</p>
          <p class="kgt-card-text">You can modify or cancel your order within 24 hours of placing it, before production begins. Contact us as soon as possible.</p>
        </div>
        <div class="kgt-card">
          <span class="kgt-card-icon">&#127942;</span>
          <p class="kgt-card-title">Bulk and Team Orders</p>
          <p class="kgt-card-text">Need 5 or more trophies for a tournament or team? Contact us for bulk pricing and we will put together a custom quote.</p>
        </div>
        <div class="kgt-card">
          <span class="kgt-card-icon">&#128444;</span>
          <p class="kgt-card-title">Logo and Image Requests</p>
          <p class="kgt-card-text">Want your team logo or custom image on the trophy? Send us the file (PNG or SVG preferred) via the order notes or email us directly.</p>
        </div>
        <div class="kgt-card">
          <span class="kgt-card-icon">&#9989;</span>
          <p class="kgt-card-title">Quality Guarantee</p>
          <p class="kgt-card-text">If your trophy arrives damaged or does not match what was agreed, we will replace it at no cost. Just contact us with a photo within 7 days.</p>
        </div>
        <div class="kgt-card">
          <span class="kgt-card-icon">&#128172;</span>
          <p class="kgt-card-title">Have Questions?</p>
          <p class="kgt-card-text">Not sure about something? Reach out before ordering -- we respond within 24 hours and are happy to help you design the perfect trophy.</p>
        </div>
      </div>
    </div>
  </div>

  <div class="kgt-faq-wrap">
    <p class="kgt-label">FAQ</p>
    <h2 class="kgt-heading">Common Questions</h2>
    <div class="kgt-faq-list">

      <div class="kgt-faq-item">
        <button class="kgt-faq-q" aria-expanded="false">
          Can I see a preview before it is made?
          <span class="kgt-faq-icon">+</span>
        </button>
        <div class="kgt-faq-a">For complex custom designs with logos or multiple lines of text, we will send you a digital proof via email before production begins. Simple text engravings are produced directly from your order notes.</div>
      </div>

      <div class="kgt-faq-item">
        <button class="kgt-faq-q" aria-expanded="false">
          What if I make a typo in the personalisation?
          <span class="kgt-faq-icon">+</span>
        </button>
        <div class="kgt-faq-a">If you spot a mistake before we confirm the design, just contact us and we will fix it. We always double-check personalisation details before starting production so you will have a chance to catch errors.</div>
      </div>

      <div class="kgt-faq-item">
        <button class="kgt-faq-q" aria-expanded="false">
          Do you ship internationally?
          <span class="kgt-faq-icon">+</span>
        </button>
        <div class="kgt-faq-a">Yes, we ship worldwide. International delivery times vary by destination. Customs fees and import duties if applicable are the responsibility of the buyer.</div>
      </div>

      <div class="kgt-faq-item">
        <button class="kgt-faq-q" aria-expanded="false">
          How far in advance should I order for an event?
          <span class="kgt-faq-icon">+</span>
        </button>
        <div class="kgt-faq-a">We recommend ordering at least 2 weeks before your event to allow time for production (3 to 5 days) and shipping (3 to 7 days). For bulk orders or complex designs, give yourself 3 weeks to be safe.</div>
      </div>

      <div class="kgt-faq-item">
        <button class="kgt-faq-q" aria-expanded="false">
          What materials are the trophies made from?
          <span class="kgt-faq-icon">+</span>
        </button>
        <div class="kgt-faq-a">Materials vary by product -- check the individual product pages for specific details. Most of our trophies are made from high-quality resin, acrylic, or PLA/PETG with a durable finish.</div>
      </div>

      <div class="kgt-faq-item">
        <button class="kgt-faq-q" aria-expanded="false">
          Can I order for a gaming tournament or esports event?
          <span class="kgt-faq-icon">+</span>
        </button>
        <div class="kgt-faq-a">Absolutely. We specialise in gaming and esports awards. We can incorporate game logos, controller designs, team names, and player tags. Contact us to discuss your event and we will make it memorable.</div>
      </div>

    </div>
  </div>

  <div class="kgt-cta">
    <h2>Ready to Order?</h2>
    <p>Browse our trophy range or get in touch if you need help designing something custom.</p>
    <div class="kgt-cta-btns">
      <a href="/collections/all" class="kgt-btn kgt-btn--primary">Shop Trophies</a>
      <a href="/pages/contact" class="kgt-btn kgt-btn--secondary">Contact Us</a>
    </div>
  </div>

</div>

<script>
  document.querySelectorAll('.kgt-faq-q').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var item = btn.closest('.kgt-faq-item');
      var isOpen = item.classList.contains('open');
      document.querySelectorAll('.kgt-faq-item').forEach(function(i) { i.classList.remove('open'); });
      if (!isOpen) item.classList.add('open');
      btn.setAttribute('aria-expanded', String(!isOpen));
    });
  });
</script>

{% schema %}
{
  "name": "Trophy Order Guide",
  "tag": "section",
  "class": "section",
  "settings": [],
  "presets": [{ "name": "Trophy Order Guide" }]
}
{% endschema %}
