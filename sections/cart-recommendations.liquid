<section class="section kg3d-page kg3d-recommendations" id="cart-recommendations-{{ section.id }}">
  <div class="container">
    <header class="kg3d-mini-header"><h2>{{ section.settings.heading }}</h2></header>
    <div class="kg3d-rec-grid">
      {% for product in collections.all.products limit: 4 %}
        <article class="kg3d-rec-card">
          <a href="{{ product.url }}" class="kg3d-rec-card__media">{% if product.featured_image %}{{ product.featured_image | image_url: width: 520 | image_tag: loading: 'lazy', widths: '260, 520', sizes: '(min-width: 900px) 25vw, 100vw', alt: product.title }}{% endif %}</a>
          <div class="kg3d-rec-card__body"><a href="{{ product.url }}"><h3>{{ product.title }}</h3></a><p>{{ product.price | money }}</p>{% if product.available %}<form method="post" action="/cart/add"><input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}"><button type="submit" class="btn btn-outline">Add</button></form>{% endif %}</div>
        </article>
      {% endfor %}
    </div>
  </div>
</section>
<style>.kg3d-page{--kg-bg:#05070d;--kg-panel:rgba(9,14,24,.92);--kg-soft:rgba(13,22,36,.72);--kg-line:rgba(151,195,255,.18);background:var(--kg-bg);color:#f6fbff}.kg3d-mini-header h2{color:#f6fbff;text-align:center}.kg3d-rec-grid{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:1rem}.kg3d-rec-card{background:linear-gradient(145deg,var(--kg-panel),var(--kg-soft));border:1px solid var(--kg-line);border-radius:20px;overflow:hidden}.kg3d-rec-card__media{display:block;aspect-ratio:1/1}.kg3d-rec-card__media img{width:100%;height:100%;object-fit:cover}.kg3d-rec-card__body{padding:1rem}.kg3d-rec-card h3{font-size:1rem;color:#f6fbff}.kg3d-rec-card p{color:#7fe7ff;font-weight:800}@media(max-width:900px){.kg3d-rec-grid{grid-template-columns:repeat(2,1fr)}}@media(max-width:560px){.kg3d-rec-grid{grid-template-columns:1fr}}</style>
{% schema %}
{"name":"Cart Recommendations","settings":[{"type":"text","id":"heading","label":"Heading","default":"You might also like"}]}
{% endschema %}
