<section class="section kg3d-page kg3d-recommendations" id="product-recommendations-{{ section.id }}">
  <div class="container">
    <header class="kg3d-mini-header"><h2>{{ section.settings.heading }}</h2></header>
    <div class="kg3d-rec-grid">
      {% for recommended_product in recommendations.products limit: 4 %}
        <article class="kg3d-rec-card"><a href="{{ recommended_product.url }}" class="kg3d-rec-card__media">{% if recommended_product.featured_image %}{{ recommended_product.featured_image | image_url: width: 520 | image_tag: loading: 'lazy', widths: '260, 520', sizes: '(min-width: 900px) 25vw, 100vw', alt: recommended_product.title }}{% endif %}</a><div class="kg3d-rec-card__body"><a href="{{ recommended_product.url }}"><h3>{{ recommended_product.title }}</h3></a><p>{{ recommended_product.price | money }}</p></div></article>
      {% else %}
        {% for fallback_product in collections.all.products limit: 4 %}<article class="kg3d-rec-card"><a href="{{ fallback_product.url }}" class="kg3d-rec-card__media">{% if fallback_product.featured_image %}{{ fallback_product.featured_image | image_url: width: 520 | image_tag: loading: 'lazy', widths: '260, 520', sizes: '(min-width: 900px) 25vw, 100vw', alt: fallback_product.title }}{% endif %}</a><div class="kg3d-rec-card__body"><a href="{{ fallback_product.url }}"><h3>{{ fallback_product.title }}</h3></a><p>{{ fallback_product.price | money }}</p></div></article>{% endfor %}
      {% endfor %}
    </div>
  </div>
</section>
<style>.kg3d-page{--kg-bg:#05070d;--kg-panel:rgba(9,14,24,.92);--kg-soft:rgba(13,22,36,.72);--kg-line:rgba(151,195,255,.18);background:var(--kg-bg);color:#f6fbff}.kg3d-mini-header h2{color:#f6fbff;text-align:center}.kg3d-rec-grid{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:1rem}.kg3d-rec-card{background:linear-gradient(145deg,var(--kg-panel),var(--kg-soft));border:1px solid var(--kg-line);border-radius:20px;overflow:hidden}.kg3d-rec-card__media{display:block;aspect-ratio:1/1}.kg3d-rec-card__media img{width:100%;height:100%;object-fit:cover}.kg3d-rec-card__body{padding:1rem}.kg3d-rec-card h3{font-size:1rem;color:#f6fbff}.kg3d-rec-card p{color:#7fe7ff;font-weight:800}@media(max-width:900px){.kg3d-rec-grid{grid-template-columns:repeat(2,1fr)}}@media(max-width:560px){.kg3d-rec-grid{grid-template-columns:1fr}}</style>
{% schema %}
{"name":"Product Recommendations","settings":[{"type":"text","id":"heading","label":"Heading","default":"You may also like"},{"type":"checkbox","id":"show_vendor","label":"Show vendor","default":false}]}
{% endschema %}
