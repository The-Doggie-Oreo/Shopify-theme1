<section class="section kg3d-page kg3d-product" id="product-{{ section.id }}">
  <div class="container kg3d-product__grid">
    <div class="kg3d-product__media">
      {% if product.featured_image %}{{ product.featured_image | image_url: width: 1200 | image_tag: loading: 'eager', widths: '500, 800, 1200', sizes: '(min-width: 990px) 50vw, 100vw', alt: product.title }}{% endif %}
      {% if product.images.size > 1 %}<div class="kg3d-thumbs">{% for image in product.images limit: 5 %}{{ image | image_url: width: 180 | image_tag: loading: 'lazy', widths: '90, 180', sizes: '90px', alt: product.title }}{% endfor %}</div>{% endif %}
    </div>
    <div class="kg3d-product__panel">
      <p class="kg3d-eyebrow">Fabrication Product</p>
      <h1>{{ product.title }}</h1>
      {% if section.settings.show_vendor and product.vendor != blank %}<p class="kg3d-muted">{{ product.vendor }}</p>{% endif %}
      {% if section.settings.show_sku and product.selected_or_first_available_variant.sku != blank %}<p class="kg3d-muted">SKU: {{ product.selected_or_first_available_variant.sku }}</p>{% endif %}
      <div class="kg3d-price">{{ product.selected_or_first_available_variant.price | money }}</div>
      <div class="kg3d-description">{{ product.description }}</div>
      {% form 'product', product, class: 'kg3d-product-form' %}
        {% unless product.has_only_default_variant %}
          <label for="ProductSelect-{{ section.id }}">Variant</label>
          <select id="ProductSelect-{{ section.id }}" name="id">{% for variant in product.variants %}<option value="{{ variant.id }}" {% if variant == product.selected_or_first_available_variant %}selected{% endif %} {% unless variant.available %}disabled{% endunless %}>{{ variant.title }}{% unless variant.available %} - Sold out{% endunless %}</option>{% endfor %}</select>
        {% else %}
          <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
        {% endunless %}
        <label for="Quantity-{{ section.id }}">Quantity</label><input id="Quantity-{{ section.id }}" type="number" name="quantity" value="1" min="1">
        <button type="submit" name="add" class="btn btn-primary" {% unless product.selected_or_first_available_variant.available %}disabled{% endunless %}>{% if product.selected_or_first_available_variant.available %}Add to Cart{% else %}Sold Out{% endif %}</button>
        {% if section.settings.show_payment_button %}{{ form | payment_button }}{% endif %}
      {% endform %}
      {% if section.settings.show_share_buttons %}<div class="kg3d-share"><span>Share:</span><a href="https://www.facebook.com/sharer/sharer.php?u={{ shop.url }}{{ product.url }}" target="_blank">Facebook</a><a href="https://twitter.com/intent/tweet?url={{ shop.url }}{{ product.url }}&text={{ product.title | url_encode }}" target="_blank">X</a></div>{% endif %}
    </div>
  </div>
</section>
<style>.kg3d-page{--kg-bg:#05070d;--kg-panel:rgba(9,14,24,.92);--kg-soft:rgba(13,22,36,.72);--kg-line:rgba(151,195,255,.18);background:radial-gradient(circle at 15% 12%,rgba(0,194,255,.13),transparent 30rem),linear-gradient(rgba(151,195,255,.035) 1px,transparent 1px),linear-gradient(90deg,rgba(151,195,255,.035) 1px,transparent 1px),var(--kg-bg);background-size:auto,52px 52px,52px 52px,auto;color:#f6fbff}.kg3d-product__grid{display:grid;grid-template-columns:1fr 460px;gap:2rem}.kg3d-product__media,.kg3d-product__panel{background:linear-gradient(145deg,var(--kg-panel),var(--kg-soft));border:1px solid var(--kg-line);border-radius:24px;box-shadow:0 24px 80px rgba(0,0,0,.32);overflow:hidden}.kg3d-product__media>img{width:100%;height:auto}.kg3d-thumbs{display:grid;grid-template-columns:repeat(5,1fr);gap:.5rem;padding:1rem}.kg3d-thumbs img{border-radius:12px}.kg3d-product__panel{padding:1.5rem}.kg3d-eyebrow{letter-spacing:.16em;text-transform:uppercase;color:#7fe7ff;font-weight:800}.kg3d-product h1{color:#f6fbff;letter-spacing:-.05em}.kg3d-muted,.kg3d-description{color:rgba(229,241,255,.7)}.kg3d-price{font-size:2rem;color:#7fe7ff;font-weight:900;margin:1rem 0}.kg3d-product-form{display:grid;gap:.9rem;margin-top:1.5rem}.kg3d-product-form select,.kg3d-product-form input{background:rgba(255,255,255,.05);border:1px solid var(--kg-line);border-radius:12px;color:#fff;padding:.8rem}.kg3d-share{display:flex;gap:1rem;margin-top:1.5rem}.kg3d-share a{color:#7fe7ff}@media(max-width:950px){.kg3d-product__grid{grid-template-columns:1fr}}</style>
{% schema %}
{"name":"Main Product","settings":[{"type":"checkbox","id":"show_share_buttons","label":"Show share buttons","default":true},{"type":"checkbox","id":"show_vendor","label":"Show vendor","default":false},{"type":"checkbox","id":"show_sku","label":"Show SKU","default":true},{"type":"checkbox","id":"show_payment_button","label":"Show dynamic checkout","default":true}]}
{% endschema %}
